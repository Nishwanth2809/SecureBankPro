# ── SecureBankPro — Environment Variables Template ───────────────────────────
# Copy this file to docker/.env and fill in real values.
# NEVER commit docker/.env to git (it's in .gitignore).
#
# For local Docker Compose:    docker compose -f docker/docker-compose.yml up
# For Railway/Render/cloud:    set these as environment variables in the dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL Session Pooler) ─────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Session pooler (port 6543)
DB_URL=jdbc:postgresql://aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.pdyxkuipjjyewqeupwkq
DB_PASSWORD=YOUR_SUPABASE_PASSWORD_HERE

# For local Docker Compose PostgreSQL (overrides DB_URL above):
# DB_URL=jdbc:postgresql://securebank-db:5432/securebank
# DB_USERNAME=postgres
# DB_PASSWORD=localdev123

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_BASE64_STRING_IN_PRODUCTION
JWT_EXPIRATION_MS=86400000

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
